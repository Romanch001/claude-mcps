# Caddyfile — reverse proxy for all 25 MCP servers on a single DigitalOcean Droplet.
#
# Requirements:
#   - Set DOMAIN env var before starting (e.g. export DOMAIN=mcps.example.com)
#   - Add a wildcard DNS A record:  *.mcps.example.com → <Droplet IP>
#   - Caddy handles TLS automatically via Let's Encrypt.
#
# Each MCP is then reachable at:
#   https://strava-mcp.mcps.example.com/sse       ← claude.ai MCP URL
#   https://strava-mcp.mcps.example.com/health    ← keepalive ping

{
    email {$ADMIN_EMAIL:admin@example.com}
}

# ── Design / CAD Tools ────────────────────────────────────────────────────────
blender-mcp.{$DOMAIN} {
    reverse_proxy blender-mcp:8000
}
freecad-mcp.{$DOMAIN} {
    reverse_proxy freecad-mcp:8000
}
openscad-mcp.{$DOMAIN} {
    reverse_proxy openscad-mcp:8000
}
arduino-mcp.{$DOMAIN} {
    reverse_proxy arduino-mcp:8000
}

