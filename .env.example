# .env.example — copy to .env and fill in your values.
# Never commit .env to git.

# ── Domain & TLS ─────────────────────────────────────────────────────────────
# Your base domain. Each MCP gets a subdomain: strava-mcp.$DOMAIN
# Add a wildcard DNS A record: *.$DOMAIN → <Droplet IP>
DOMAIN=mcps.example.com
ADMIN_EMAIL=your-email@example.com

# ── Smart Home ────────────────────────────────────────────────────────────────
HA_URL=https://your-homeassistant.local:8123
HA_TOKEN=

# ── Music / Entertainment ─────────────────────────────────────────────────────
# developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── Social / Community ────────────────────────────────────────────────────────
# Discord channel → Integrations → Webhooks → Copy Webhook URL
DISCORD_WEBHOOK_URL=

# ── Knowledge / Reference ─────────────────────────────────────────────────────
# developer.wolframalpha.com/access → get AppID
WOLFRAM_APP_ID=

# ── Productivity ──────────────────────────────────────────────────────────────
# notion.so/my-integrations → create Internal Integration → copy token
NOTION_API_KEY=

# ── Google Services ───────────────────────────────────────────────────────────
# console.cloud.google.com → enable each API → create API key
GOOGLE_MAPS_API_KEY=
GOOGLE_TRANSLATE_API_KEY=

# console.cloud.google.com → IAM → Service Accounts → create key (JSON)
# Paste the full JSON content (single line) here
GOOGLE_SERVICE_ACCOUNT_JSON=

# developers.google.com/oauthplayground → Photos Library API scope
GOOGLE_PHOTOS_ACCESS_TOKEN=

# ── Fitness / Health ──────────────────────────────────────────────────────────
# strava.com/settings/api → create app, then complete OAuth flow (see strava-mcp/server.py)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# ── Transport / Travel ────────────────────────────────────────────────────────
# rapidapi.com → Indian Railways API (optional — IRCTC works with public data too)
RAPIDAPI_KEY=

# URL to a GTFS zip feed (optional — defaults to Indian cities if blank)
GTFS_FEED_URL=
